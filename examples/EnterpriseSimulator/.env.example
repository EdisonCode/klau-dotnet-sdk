# ──────────────────────────────────────────────────────────────────────────────
# Klau SDK Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# This file is git-ignored and should NOT be committed.
# ──────────────────────────────────────────────────────────────────────────────

# Your Klau API key (starts with kl_live_)
# Generate at: Settings > Developer in your Klau dashboard
KLAU_API_KEY=kl_live_YOUR_API_KEY_HERE

# Klau API base URL
# Production: https://api.getklau.com
# Staging:    https://api.staging.getklau.com
KLAU_BASE_URL=https://api.getklau.com

# Your division (tenant) ID — only needed for enterprise/multi-division accounts.
#
# To find your division ID, run this snippet:
#
#   var klau = new KlauClient("kl_live_YOUR_KEY");
#   var divisions = await klau.Divisions.ListAsync();
#   foreach (var div in divisions)
#       Console.WriteLine($"{div.Name}: {div.Id}");
#
# Single-location companies should leave this blank.
KLAU_DIVISION_ID=
